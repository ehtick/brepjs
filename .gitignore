.claude/agent-memory-local/

# Git worktrees
.worktrees/

# Benchmark npm version cache
.bench-cache/

node_modules
dist/

# V8 profiling artifacts
*.cpuprofile
isolate-*.log
docs-api/
coverage/
*.tsbuildinfo
.env
.vercel

# WASM build artifacts (generated by OpenCascade build process)
packages/brepjs-opencascade/build-config/*.js
packages/brepjs-opencascade/build-config/*.wasm
packages/brepjs-opencascade/build-config/*.d.ts
packages/brepjs-opencascade/src/*.js
packages/brepjs-opencascade/src/*.wasm
