# Claude Code agent memory (user-specific, not shared) — any package, any depth
**/.claude/agent-memory-local/
.claude/scheduled_tasks.lock

# Superpowers brainstorming/spec/plan docs (local working artifacts, not shared)
docs/superpowers/

# Git worktrees
.worktrees/

# Benchmark npm version cache
.bench-cache/

node_modules
dist/

# Generated at build: bundled API reference copied from the repo-root llms*.txt
packages/brepjs-verify/reference/

# V8 profiling artifacts
*.cpuprofile
isolate-*.log
docs-api/
coverage/
.vitest-reports/
*.tsbuildinfo
.env
.vercel

# WASM build artifacts (generated by OpenCascade build process)
packages/brepjs-opencascade/build-config/*.js
packages/brepjs-opencascade/build-config/*.wasm
packages/brepjs-opencascade/build-config/*.d.ts
packages/brepjs-opencascade/src/*.js
packages/brepjs-opencascade/src/*.wasm
