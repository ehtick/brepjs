# brepkit WASM build artifacts
packages/brepkit-wasm/
src/kernel/wasm/

# Ad-hoc test scripts
test-*.mjs

# npm pack output
*.tgz

# Auto-generated docs test (regenerated from apps/docs/**/*.md)
tests/docs/extracted.test.ts

# VitePress build outputs
apps/docs/.vitepress/cache/
apps/docs/.vitepress/dist/

# Playground build outputs
apps/playground/dist/

# Scratch: OpenSCAD reference clone, example screenshots, candidate scratch, etc.
tmp/
**/tmp/
