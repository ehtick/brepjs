{
  "name": "brepjs-bim",
  "version": "0.3.1",
  "description": "BIM layer for brepjs — IFC4-aligned parametric building elements",
  "keywords": [
    "bim",
    "ifc",
    "cad",
    "brep"
  ],
  "author": "Andy Aragon",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/andymai/brepjs",
    "directory": "packages/brepjs-bim"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/brepjs-bim.cjs",
  "module": "./dist/brepjs-bim.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/brepjs-bim.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/brepjs-bim.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests"
  },
  "peerDependencies": {
    "brepjs": ">=18.0.0",
    "web-ifc": ">=0.0.50"
  },
  "devDependencies": {
    "@eslint/js": "*",
    "eslint": "*",
    "typescript": "*",
    "typescript-eslint": "*",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.0",
    "web-ifc": "^0.0.77",
    "zod": "^4.4.3"
  }
}
