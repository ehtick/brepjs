{
  "name": "brepjs-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:deps": "npm -C ../../packages/brepjs-bim run build && npm -C ../../packages/brepjs-sheetmetal run build && npm -C ../../packages/brepjs-viewer run build",
    "predev": "npm run build:deps",
    "dev": "vite",
    "prebuild": "npm run build:deps",
    "build": "tsc -b && npm run check:examples && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "check:examples": "npx tsx scripts/checkExamples.ts",
    "smoke": "npx tsx scripts/smoke.ts",
    "shoot": "npx tsx scripts/shootExamples.ts",
    "thumbs": "npx tsx scripts/shootExamples.ts --thumbs",
    "turntables": "npx tsx scripts/shootExamples.ts --turntable",
    "gallery:e2e": "npx tsx scripts/galleryE2e.ts",
    "generate-types": "npx tsx scripts/generate-ambient-types.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "brepjs": "*",
    "brepjs-bim": "*",
    "brepjs-sheetmetal": "*",
    "brepjs-viewer": "*",
    "lz-string": "1.5.0",
    "monaco-editor": "0.55.1",
    "occt-wasm": "*",
    "posthog-js": "1.391.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-resizable-panels": "4.11.2",
    "sucrase": "3.35.1",
    "three": "0.184.0",
    "web-ifc": "0.0.77",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "puppeteer": "25.1.0",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
