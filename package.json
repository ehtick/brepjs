{
  "name": "brepjs",
  "version": "18.15.0",
  "description": "Web CAD library with pluggable geometry kernel",
  "keywords": [
    "cad",
    "geometry-kernel",
    "brep",
    "STEP",
    "STL"
  ],
  "author": "Andy Aragon",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/andymai/brepjs"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "packages/brepjs-opencascade",
    "apps/playground",
    "apps/docs"
  ],
  "main": "./dist/brepjs.cjs",
  "module": "./dist/brepjs.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/brepjs.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/brepjs.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.cjs"
      }
    },
    "./result": {
      "import": {
        "types": "./dist/result.d.ts",
        "default": "./dist/result.js"
      },
      "require": {
        "types": "./dist/result.d.ts",
        "default": "./dist/result.cjs"
      }
    },
    "./vectors": {
      "import": {
        "types": "./dist/vectors.d.ts",
        "default": "./dist/vectors.js"
      },
      "require": {
        "types": "./dist/vectors.d.ts",
        "default": "./dist/vectors.cjs"
      }
    },
    "./topology": {
      "import": {
        "types": "./dist/topology.d.ts",
        "default": "./dist/topology.js"
      },
      "require": {
        "types": "./dist/topology.d.ts",
        "default": "./dist/topology.cjs"
      }
    },
    "./operations": {
      "import": {
        "types": "./dist/operations.d.ts",
        "default": "./dist/operations.js"
      },
      "require": {
        "types": "./dist/operations.d.ts",
        "default": "./dist/operations.cjs"
      }
    },
    "./2d": {
      "import": {
        "types": "./dist/2d.d.ts",
        "default": "./dist/2d.js"
      },
      "require": {
        "types": "./dist/2d.d.ts",
        "default": "./dist/2d.cjs"
      }
    },
    "./sketching": {
      "import": {
        "types": "./dist/sketching.d.ts",
        "default": "./dist/sketching.js"
      },
      "require": {
        "types": "./dist/sketching.d.ts",
        "default": "./dist/sketching.cjs"
      }
    },
    "./text": {
      "import": {
        "types": "./dist/text.d.ts",
        "default": "./dist/text.js"
      },
      "require": {
        "types": "./dist/text.d.ts",
        "default": "./dist/text.cjs"
      }
    },
    "./projection": {
      "import": {
        "types": "./dist/projection.d.ts",
        "default": "./dist/projection.js"
      },
      "require": {
        "types": "./dist/projection.d.ts",
        "default": "./dist/projection.cjs"
      }
    },
    "./query": {
      "import": {
        "types": "./dist/query.d.ts",
        "default": "./dist/query.js"
      },
      "require": {
        "types": "./dist/query.d.ts",
        "default": "./dist/query.cjs"
      }
    },
    "./measurement": {
      "import": {
        "types": "./dist/measurement.d.ts",
        "default": "./dist/measurement.js"
      },
      "require": {
        "types": "./dist/measurement.d.ts",
        "default": "./dist/measurement.cjs"
      }
    },
    "./io": {
      "import": {
        "types": "./dist/io.d.ts",
        "default": "./dist/io.js"
      },
      "require": {
        "types": "./dist/io.d.ts",
        "default": "./dist/io.cjs"
      }
    },
    "./worker": {
      "import": {
        "types": "./dist/worker.d.ts",
        "default": "./dist/worker.js"
      },
      "require": {
        "types": "./dist/worker.d.ts",
        "default": "./dist/worker.cjs"
      }
    },
    "./shapeRef": {
      "import": {
        "types": "./dist/shapeRef.d.ts",
        "default": "./dist/shapeRef.js"
      },
      "require": {
        "types": "./dist/shapeRef.d.ts",
        "default": "./dist/shapeRef.cjs"
      }
    },
    "./quick": {
      "import": {
        "types": "./dist/quick.d.ts",
        "default": "./dist/quick.js"
      }
    },
    "./kernel/occtWasm/occtWasmAdapter": {
      "import": {
        "types": "./dist/kernel/occtWasm/occtWasmAdapter.d.ts",
        "default": "./dist/kernel/occtWasm/occtWasmAdapter.js"
      },
      "require": {
        "types": "./dist/kernel/occtWasm/occtWasmAdapter.d.ts",
        "default": "./dist/kernel/occtWasm/occtWasmAdapter.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && node scripts/build-quick.js",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build",
    "prepack": "bash scripts/validate-pack.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run --project occt --changed",
    "test:full": "vitest run --project occt --coverage",
    "test:watch": "vitest --project occt",
    "test:brepkit": "vitest run --project brepkit",
    "test:stress": "vitest run --config vitest.stress.config.ts",
    "check:boundaries": "bash scripts/check-layer-boundaries.sh",
    "bench": "vitest run --config vitest.bench.config.ts",
    "bench:compare": "BENCH_KERNELS=both vitest run --config vitest.bench.config.ts",
    "bench:json": "BENCH_KERNELS=both BENCH_OUTPUT_JSON=1 vitest run --config vitest.bench.config.ts",
    "check:boundaries:staged": "bash scripts/check-layer-boundaries.sh --staged",
    "check:patterns": "npx tsx scripts/check-patterns.ts",
    "check:patterns:baseline": "npx tsx scripts/check-patterns.ts --update-baseline",
    "check:readme-reminders": "bash scripts/check-readme-reminders.sh",
    "knip": "knip",
    "validate": "bash scripts/validate-change.sh",
    "size": "size-limit",
    "docs:api": "typedoc",
    "docs:generate-lookup": "npx tsx scripts/generate-function-lookup.ts",
    "docs:dev": "npm -C apps/docs run dev",
    "docs:build": "npm -C apps/docs run build",
    "docs:preview": "npm -C apps/docs run preview",
    "docs:extract-tests": "npx tsx scripts/extract-doc-tests.ts",
    "docs:render-images": "npx tsx scripts/render-doc-images.ts",
    "gen:og": "bash scripts/gen-og.sh",
    "test:docs": "npm run docs:extract-tests && vitest run --project occt tests/docs",
    "conformance:generate": "npx tsx scripts/generateConformance.ts",
    "sync:brepkit-types": "npx tsx scripts/sync-brepkit-types.ts",
    "prepare": "husky && bash scripts/ensure-wasm.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint/js": "10.0.1",
    "@size-limit/file": "12.1.0",
    "@types/opentype.js": "1.3.9",
    "@vitest/coverage-v8": "4.1.6",
    "brepjs-opencascade": "*",
    "brepkit-wasm": "2.88.0",
    "eslint": "10.4.0",
    "fast-check": "4.8.0",
    "husky": "9.1.7",
    "knip": "6.14.1",
    "lint-staged": "17.0.5",
    "lz-string": "1.5.0",
    "occt-wasm": "3.1.0",
    "prettier": "3.8.3",
    "puppeteer": "25.0.2",
    "size-limit": "12.1.0",
    "sucrase": "3.35.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-dts": "5.0.0",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "brepjs-opencascade": "^0.5.1 || ^0.6.0 || ^0.7.0 || ^0.8.0 || ^0.9.0 || ^0.10.0 || ^0.11.0 || ^0.12.0 || ^0.13.0 || ^0.14.0 || ^0.15.0",
    "brepkit-wasm": "^0.10.1 || ^1.0.0 || ^2.0.0",
    "occt-wasm": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "brepjs-opencascade": {
      "optional": true
    },
    "brepkit-wasm": {
      "optional": true
    },
    "occt-wasm": {
      "optional": true
    }
  },
  "dependencies": {
    "flatbush": "4.5.1",
    "opentype.js": "1.3.4"
  },
  "overrides": {
    "minimatch@>=10.0.0 <10.2.3": "10.2.3"
  }
}
